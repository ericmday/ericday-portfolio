---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Eric Day — AI Creative Supervisor, Creative Technology Director" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <script>
      // Theme toggle
      const toggle = document.getElementById('theme-toggle');
      const root = document.documentElement;

      // Check for saved preference or default to dark
      const savedTheme = localStorage.getItem('theme') || 'dark';
      root.setAttribute('data-theme', savedTheme);

      toggle?.addEventListener('click', () => {
        const current = root.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        root.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
      });

      // Slide-up animation on scroll
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      }, { threshold: 0.1 });

      document.querySelectorAll('.slide-up').forEach(el => observer.observe(el));

      // Scroll capture for Selected Works section
      const scrollableSection = document.querySelector('.section-scrollable');
      const scrollContainer = document.querySelector('.project-scroll-container');

      if (scrollableSection && scrollContainer) {
        let isInView = false;

        const sectionObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            isInView = entry.isIntersecting && entry.intersectionRatio > 0.95;
          });
        }, { threshold: [0.95, 1] });

        sectionObserver.observe(scrollableSection);

        window.addEventListener('wheel', (e) => {
          if (!isInView) return;

          const { scrollTop, scrollHeight, clientHeight } = scrollContainer;
          const atTop = scrollTop <= 0;
          const atBottom = scrollTop + clientHeight >= scrollHeight - 1;

          // Scrolling down and not at bottom, or scrolling up and not at top
          if ((e.deltaY > 0 && !atBottom) || (e.deltaY < 0 && !atTop)) {
            e.preventDefault();
            scrollContainer.scrollTop += e.deltaY;
          }
        }, { passive: false });
      }

      // Scroll-linked horizontal gallery
      const galleryStrip = document.getElementById('gallery-strip');
      const galleryInner = document.getElementById('gallery-inner');
      const originSection = document.getElementById('origin-section');

      if (galleryStrip && galleryInner && originSection) {
        let scrollStart = null;

        const updateGallery = () => {
          const rect = originSection.getBoundingClientRect();
          const windowHeight = window.innerHeight;

          // Check if section is mostly visible (75%+)
          const visibleHeight = Math.min(rect.bottom, windowHeight) - Math.max(rect.top, 0);
          const visibleRatio = visibleHeight / windowHeight;
          const isActive = rect.top <= windowHeight * 0.25 && rect.bottom > windowHeight * 0.1;

          if (isActive) {
            // Fade in/out
            const fadeIn = visibleRatio >= 0.75 ? 1 : visibleRatio / 0.75;
            const fadeOut = Math.min(1, rect.bottom / (windowHeight * 0.3));
            galleryStrip.style.opacity = Math.min(fadeIn, fadeOut);

            // Track scroll start position
            if (scrollStart === null) {
              scrollStart = window.scrollY;
            }

            // Calculate progress based on how much we've scrolled since activation
            const scrollDistance = windowHeight * 1.5; // Slower scroll, never quite reaches end
            const scrolled = window.scrollY - scrollStart;
            const scrollProgress = Math.max(0, Math.min(0.85, scrolled / scrollDistance)); // Cap at 85%

            // Move gallery horizontally
            const maxMove = galleryInner.scrollWidth - galleryStrip.clientWidth + 200;
            const translateX = -scrollProgress * maxMove;
            galleryInner.style.transform = `translateX(${translateX}px)`;
          } else {
            galleryStrip.style.opacity = '0';
            scrollStart = null; // Reset when section leaves
          }
        };

        window.addEventListener('scroll', updateGallery, { passive: true });
        updateGallery();
      }

    </script>
  </body>
</html>

<style is:global>
  :root {
    --font: "Courier New", Courier, monospace;
  }

  [data-theme="light"] {
    --bg: #ffffff;
    --bg-rgb: 255, 255, 255;
    --fg: #1a1a1a;
    --muted: #666;
    --border: #d0d0d0;
  }

  [data-theme="dark"] {
    --bg: #0a0a0a;
    --bg-rgb: 10, 10, 10;
    --fg: #f0f0f0;
    --muted: #888;
    --border: #2a2a2a;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--fg);
    font-family: var(--font);
    transition: background 0.3s ease, color 0.3s ease;
  }

  a {
    color: var(--fg);
    text-decoration: none;
    border-bottom: 1px solid var(--border);
  }

  a:hover {
    border-color: var(--fg);
  }

  .light-label { display: inline; }
  .dark-label { display: none; }
  [data-theme="light"] .light-label { display: none; }
  [data-theme="light"] .dark-label { display: inline; }
</style>
